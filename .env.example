# =============================================================================
# Beyond Workz API — copy to .env and fill values
# Naming: SERVICE_PURPOSE (e.g. AWS_SES_* for SES only, AWS_S3_* for S3 only)
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=5001
NODE_ENV=development

# Optional: cap /api/auth/* requests per 15 minutes (default 100)
# AUTH_RATE_LIMIT_MAX=100

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://127.0.0.1:27017/beyondworkz
# MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=beyondworkz

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=replace_with_long_random_hex_or_string
JWT_REFRESH_SECRET=replace_with_different_long_random_secret
ACCESS_EXPIRES=15m
REFRESH_EXPIRES=7d

# -----------------------------------------------------------------------------
# AWS — region used by SES and S3
# -----------------------------------------------------------------------------
AWS_REGION=ap-south-1

# --- Amazon SES (OTP / transactional email) ---
# IAM policy must include ses:SendEmail (e.g. AmazonSESFullAccess or custom).
# From address or its domain must be verified in SES (same region as AWS_REGION).
# Sandbox mode: recipient emails must also be verified until you exit sandbox.
AWS_SES_ACCESS_KEY_ID=your_ses_iam_access_key_id
AWS_SES_SECRET_ACCESS_KEY=your_ses_iam_secret_access_key
SES_FROM_EMAIL=noreply@your-verified-domain.com

# Dev only: skip SES and print OTP in API logs (do not use in production)
# EMAIL_MODE=console

# Dev only: if NODE_ENV is not "development" but you still want OTP in logs on SES failure
# ALLOW_DEV_OTP_LOG=true

# --- Amazon S3 (avatars, resumes) ---
# IAM policy must allow s3:PutObject, s3:GetObject (and Delete if you use delete) on the bucket.
# Prefer AWS_S3_* so they never clash with SES keys.
S3_BUCKET=your-bucket-name
S3_PUBLIC_PREFIX=https://your-bucket.s3.YOUR_REGION.amazonaws.com

AWS_S3_ACCESS_KEY_ID=your_s3_iam_access_key_id
AWS_S3_SECRET_ACCESS_KEY=your_s3_iam_secret_access_key

# Legacy fallback if AWS_S3_* are unset (not recommended — easy to mix up with SES)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional file limits
# RESUME_MAX_BYTES=5242880
# AVATAR_MAX_BYTES=10485760
# ALLOWED_RESUME_TYPES=application/pdf
# ALLOWED_AVATAR_TYPES=image/jpeg,image/png,image/webp
# PRESIGN_EXPIRES_SECONDS=300

# -----------------------------------------------------------------------------
# Google OAuth 2.0 (employee app — “Sign in with Google”)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
API_BASE_URL=http://localhost:5001

# -----------------------------------------------------------------------------
# CORS — allowed frontend origin(s); must match employee/employer app URL(s)
# -----------------------------------------------------------------------------
CLIENT_URL=http://localhost:5173
