# Server
PORT=5001
NODE_ENV=development

# Rate limit: max auth requests per 15 min (default 100)
# AUTH_RATE_LIMIT_MAX=100

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/beyondworkz_db

# JWT - Access token (short-lived, stored in memory)
JWT_ACCESS_SECRET=replace_with_strong_access_secret_32chars
ACCESS_EXPIRES=15m

# JWT - Refresh token (long-lived, stored in HttpOnly cookie)
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret_32chars
REFRESH_EXPIRES=7d

# AWS SES (for OTP emails)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
SES_FROM_EMAIL=noreply@beyondworkz.com

# AWS S3 (beyond-workz bucket - images & PDFs)
# Use same AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY as jobportal-backend
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key


S3_BUCKET=beyond-workz
S3_PUBLIC_PREFIX=https://beyond-workz.s3.ap-south-1.amazonaws.com
RESUME_MAX_BYTES=5242880
ALLOWED_RESUME_TYPES=application/pdf
AVATAR_MAX_BYTES=10485760
ALLOWED_AVATAR_TYPES=image/jpeg,image/png,image/webp
PRESIGN_EXPIRES_SECONDS=300

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Google OAuth 2.0 (for Login/Register with Google)
# Can reuse same credentials as jobportal-backend - run: node scripts/sync-google-oauth-from-jobportal.mjs
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
API_BASE_URL=http://localhost:5001
